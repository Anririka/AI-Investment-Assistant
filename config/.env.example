# このファイルをコピーして .env を作成し、実際の値を入れて使う（.envは.gitignoreでコミット対象外）。
# 本番運用（GitHub Actions）では、同じキー名でリポジトリの Secrets に登録する。

# --- J-Quants（日本株） ---
# V2 APIはAPIキー方式のみ（メールアドレス・パスワードによる認証は不要）。
# https://jpx-jquants.com/dashboard/api-keys で発行したキーをそのまま貼る。
JQUANTS_API_KEY=

# --- 米国株 ---
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# --- マクロ指標 ---
FRED_API_KEY=

# --- ニュース ---
NEWSAPI_API_KEY=
# GDELTはAPIキー不要

# --- Google Drive（Layer4永続化、Layer1キャッシュ、Layer6〜8） ---
# 2026-07-22時点、サービスアカウントではなくOAuth 2.0ユーザー認証に統一した
# （サービスアカウントは個人のGoogle Driveの保存容量を持たず、新規ファイル作成が
# 403 insufficientParentPermissionsで失敗するため）。
# scripts/generate_google_oauth_token.py を1回だけローカルで実行して発行した
# {"client_id":..., "client_secret":..., "refresh_token":...} を1行のJSON文字列として貼る。
GOOGLE_OAUTH_TOKEN_JSON=
# Google Drive上のAI-Investment-AssistantフォルダのID（URLの/folders/以降の文字列）
GOOGLE_DRIVE_FOLDER_ID=
