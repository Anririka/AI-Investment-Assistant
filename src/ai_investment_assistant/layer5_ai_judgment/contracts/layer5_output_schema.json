{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Layer5 Output (Layer6 Input Contract)",
  "description": "layer5_ai_judgment_design.md §9の確定仕様。選択肢B移行後もモデルによらず一貫して通ることを検証する契約テスト対象（§12）。",
  "type": "object",
  "required": ["run_meta", "proposals", "decision_log", "rule_enforcement_log"],
  "additionalProperties": true,
  "properties": {
    "run_meta": {
      "type": "object",
      "required": [
        "run_id", "layer5_started_at", "layer5_completed_at",
        "data_quality_gate", "data_quality_gate_detail", "score_meta_ref"
      ],
      "properties": {
        "run_id": { "type": "string" },
        "layer5_started_at": { "type": "string" },
        "layer5_completed_at": { "type": "string" },
        "data_quality_gate": { "type": "string", "enum": ["passed", "warning_continued", "blocked"] },
        "data_quality_gate_detail": {
          "type": "object",
          "required": ["blocking_errors_found", "warning_errors_found"],
          "properties": {
            "blocking_errors_found": { "type": "array" },
            "warning_errors_found": { "type": "array" }
          }
        },
        "score_meta_ref": { "type": "object" }
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank", "asset_class", "ticker", "name", "overall_assessment",
          "recommended_shares", "entry_price_basis", "position_amount",
          "stop_loss_price", "take_profit_target_pct", "take_profit_price",
          "expected_return_pct", "expected_loss_pct", "confidence",
          "investment_reason", "risk_factors", "score_summary"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "asset_class": { "type": "string" },
          "ticker": { "type": "string" },
          "name": { "type": "string" },
          "overall_assessment": { "type": "string", "enum": ["buy", "sell", "hold"] },
          "recommended_shares": { "type": "integer", "minimum": 1 },
          "entry_price_basis": { "type": "number" },
          "position_amount": { "type": "number" },
          "stop_loss_price": { "type": "number" },
          "take_profit_target_pct": { "type": "number" },
          "take_profit_price": { "type": "number" },
          "take_profit_basis": { "type": "string" },
          "reference_price_type": { "type": "string" },
          "reference_price": { "type": "number" },
          "expected_return_pct": { "type": "number" },
          "expected_loss_pct": { "type": "number" },
          "risk_reward_ratio": { "type": "number" },
          "holding_period": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
          "investment_reason": { "type": "string" },
          "risk_factors": { "type": "string" },
          "score_summary": {
            "type": "object",
            "required": ["technical", "fundamental", "supply_demand", "macro", "news", "regime_fit", "composite"],
            "properties": {
              "technical": { "type": "number" },
              "fundamental": { "type": "number" },
              "supply_demand": { "type": "number" },
              "macro": { "type": "number" },
              "news": {
                "type": "object",
                "required": ["score", "uncertainty"],
                "properties": {
                  "score": { "type": "number" },
                  "uncertainty": { "type": "number" }
                }
              },
              "regime_fit": { "type": "number" },
              "composite": { "type": "number" }
            }
          },
          "alternative_candidates": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "decision_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "decision", "reason_code"],
        "properties": {
          "ticker": { "type": "string" },
          "decision": { "type": "string", "enum": ["adopted", "rejected", "not_selected"] },
          "rank": { "type": "integer" },
          "reason_code": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "rule_enforcement_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "applied"],
        "properties": {
          "rule": { "type": "string" },
          "applied": { "type": "boolean" },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
